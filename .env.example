# Panel
PANEL_HOST=0.0.0.0
PANEL_PORT=6310
PANEL_TOKEN=change-me
PUBLIC_HOST=your-server-ip-or-domain

# Proxy client auth. Leave empty only for a trusted isolated LAN.
PROXY_AUTH=fingerprint:change-me

# Mihomo
MIHOMO_API=http://127.0.0.1:6311
MIHOMO_SECRET=change-me
MIHOMO_CONTROLLER=127.0.0.1:6311
MIHOMO_CONFIG_PATH=/root/.config/mihomo/config.yaml

# Slots exposed to fingerprint browsers. Each port is mixed HTTP + SOCKS5.
# The number of ports here is the number of proxy slots the panel will expose.
SLOT_PORTS=6181,6182,6183,6184,6185,6186

# Source file is mounted at ./config/source.yaml.
SOURCE_PATH=/app/config/source.yaml
SOURCES_PATH=/app/config/sources.yaml
OUTPUT_PATH=/app/config/config.yaml
DELAY_TEST_URL=https://www.gstatic.com/generate_204

# Optional legacy single URL file. Prefer config/sources.yaml for multiple sources.
# SUBSCRIPTION_URL_FILE=/app/config/subscription-url.txt
